# SIT Environment Configuration
NODE_ENV=sit
PORT=3001

# Database Configuration for SIT
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flow_space_sit
DB_USER=postgres
DB_PASSWORD=your_sit_password

# JWT Configuration
JWT_SECRET=your_sit_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# API Configuration
API_VERSION=v1
API_BASE_URL=https://flow-space-sit.onrender.com

# Logging
LOG_LEVEL=debug
